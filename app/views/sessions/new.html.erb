<% content_for :title, "Login" %>

<div data-controller="page-alert" data-page-alert-message-value="Welcome to Login"></div>

<form action="<%= session_path %>" method="post">
  <%= csrf_meta_tags %>

  <label for="email">Email</label>
  <input type="email" name="email" id="email" required>

  <label for="password">Password</label>
  <input type="password" name="password" id="password" required>

  <input type="hidden" name="redirect_to" id="redirect_to" value="<%= params[:redirect] %>">

  <%= button do %>Login<% end %>

  <%= flash[:alert] %>
  <%= flash[:notice] %>
</form>
