<% content_for :title, "Login" %>

<div class="form-wrapper">
  <%= form_for :session, url: session_path, builder: CustomFormBuilder, class: "login-form" do |f| %>
    <%= csrf_meta_tags %>
    <%= f.hidden_field :redirect_to, value: params[:redirect] %>

    <%= f.email_field :email, required: true %>
    <%= f.password_field :password, required: true %>

    <%= f.submit text: "Login" %>

    <%= flash[:alert] %>
    <%= flash[:notice] %>
  <% end %>
</div>

<img src="" alt="Login Background" class="login-image" />